# Copy to .env and fill in only the integrations you want to use.

# Spotify live listening data
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback
SPOTIFY_OPEN_BROWSER=true

# OpenAI taste profiling, gig search, and gig enrichment
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.2

# Email report delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
EMAIL_SUBJECT=Birmingham gig recommendations
